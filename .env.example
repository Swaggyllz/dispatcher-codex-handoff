# Copy the variables you need into a local .env file. Never commit real keys.

OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
OPENROUTER_API_KEY=
DEEPSEEK_API_KEY=
SILICONFLOW_API_KEY=
XIAOMIMIMO_API_KEY=

# Optional independent credential for Codex clients routed through Dispatcher.
DISPATCHER_CODEX_API_KEY=

# The server listens on loopback by default. Set 0.0.0.0 only behind suitable
# network controls and authentication.
DISPATCHER_BIND_ADDR=127.0.0.1
